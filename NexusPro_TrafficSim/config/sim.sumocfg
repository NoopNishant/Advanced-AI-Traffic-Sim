<configuration>
    <input>
        <net-file value="map.net.xml"/>
        <route-files value="traffic.rou.xml"/>
    </input>
    <time>
        <begin value="0"/>
        <end value="3600"/>
        <step-length value="0.1"/>
    </time>
    
    <processing>
        <lateral-resolution value="0.8"/>
        <collision.action value="teleport"/> 
    </processing>
</configuration>